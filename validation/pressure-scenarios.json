    {
      "id": "S01",
      "name": "小修改但需求不清",
      "user_request": "把导出按钮文案改得更清楚一点。",
      "pressure": [
        "任务看似很小",
        "容易直接修改"
      ],
      "expected_path": [
        "start",
        "clarify",
        "tdd",
        "review",
        "finish"
      ],
      "required_evidence": [
        {
          "skill": "start",
          "contains": "需求不清"
        },
        {
          "skill": "clarify",
          "contains": "需求已清楚且只是小修改：进入 `tdd`"
        },
        {
          "skill": "tdd",
          "contains": "实现完成后进入 `review`"
        },
        {
          "skill": "review",
          "contains": "下一步进入 `finish`"
        }
      ],
      "forbidden_behavior": [
        "直接实现",
        "跳过 clarify",
        "没有最终验收"
      ]
    },
    {
